{
  "manifest_version": 3,
  "name": "TimeTiles",
  "version": "1.2.0",
  "description": "See the current time at every office at a glance, with a built-in time zone converter.",
  "permissions": ["storage", "sidePanel", "geolocation"],
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
